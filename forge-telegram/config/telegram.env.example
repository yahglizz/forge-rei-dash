# Telegram bot for FORGE REI OS alerts + tap-to-approve. Copy to telegram.env (same dir).
# 1) Telegram: message @BotFather -> /newbot -> copy the token below.
TELEGRAM_BOT_TOKEN=
# 2) Your chat id: DM your new bot, then message @userinfobot (it replies your id).
#    For a TEAM GROUP: add the bot to the group and use the group id (a negative number).
TELEGRAM_CHAT_ID=
# 3) Optional: comma-separated user/chat ids allowed to tap Approve/Dismiss buttons.
#    Defaults to TELEGRAM_CHAT_ID if blank.
TELEGRAM_ALLOWED_IDS=
