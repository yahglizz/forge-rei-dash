# =============================================================================
# FORGE NOVA — runtime config TEMPLATE (.env.example)
#
# HOW TO USE:
#   1. This is a template only. The REAL file next to it is  nova.env
#   2. Copy this file:  cp nova.env.example nova.env  then edit values.
#   3. Redeploy (push.sh) so the box reloads.
#
# Nova runs point on daycare ads: campaign health, competitor intel, and
# creative direction, grounded in the real Meta account + Higgsfield workflow
# documented in forge-daycare/skills/enrollment-ad-agent.md. She reports to
# Solomon and reads his "Ads"/"Enrollment" delegations off the shared agent
# bus. She never launches a campaign, changes budget, or generates creative on
# her own — every spend/creative action stays a one-tap owner approval (or is
# executed by a chat session with Higgsfield/Meta tool access acting on her
# delegation). Her only autonomous writes are her own brain playbook + bus
# notes.
#
# SAFETY:
#   This folder is a SIBLING of the web app ("forge rei/"), so it lives OUTSIDE
#   the web-served dir. Nothing here is reachable over HTTP. Keys stay private.
# =============================================================================

# --- Cadence -----------------------------------------------------------------
# Hours between Nova's autonomous ad-ops briefs on the box.
FORGE_NOVA_BRIEF_EVERY_H=6

# --- Self-improvement --------------------------------------------------------
# Briefs Nova must produce before an auto self-improve fires.
FORGE_NOVA_LEARN_EVERY=8
# Minimum minutes between self-improvement writes (rate guard).
FORGE_NOVA_LEARN_GAP_MIN=45

# --- Anthropic (Nova's OWN Claude key) ---------------------------------------
# Optional. Nova's dedicated key. If unset she FALLS BACK to Solomon's key,
# then the shared agency/wholesale Anthropic key, so she works before her own
# key is set.
# NOVA_ANTHROPIC_API_KEY=sk-ant-...

# --- Obsidian brain (vault) --------------------------------------------------
# Optional override for the Agentic-OS Obsidian vault path. Nova reads her
# learned playbook from <vault>/Skills/nova-playbook.md in addition to the
# local skills/nova-playbook.md in this folder.
# FORGE_VAULT=/Users/yg4st/Desktop/Agentic-OS/vault
