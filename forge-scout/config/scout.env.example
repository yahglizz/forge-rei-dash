# =============================================================================
# FORGE SCOUT — runtime config TEMPLATE (.env.example)
#
# HOW TO USE:
#   1. This is a template only. The REAL file next to it is  scout.env
#   2. Copy this file:  cp scout.env.example scout.env  then edit values.
#   3. Restart the connector (or redeploy) so it reloads.
#
# Scout is the wholesale lead-triage agent: it reads GoHighLevel seller text
# threads, scores motivation, ranks speed-to-lead, filters stop/not-interested,
# and QUEUES tags + pipeline pushes for human approval. Scout NEVER texts a
# seller — Marcus owns outbound.
#
# SAFETY:
#   This folder is a SIBLING of the web app ("forge rei/"), so it lives OUTSIDE
#   the web-served dir. Nothing here is reachable over HTTP. Keys stay private.
# =============================================================================

# --- Sweep cadence & batch sizing -------------------------------------------
# Seconds between conversation sweeps (how often Scout re-scans GHL).
FORGE_SCOUT_INTERVAL=180

# Max conversations Scout sends to Claude for scoring per pass (cost/rate guard).
FORGE_SCOUT_BATCH=15

# Conversation pages to scan from the GHL conversations endpoint per pass.
FORGE_SCOUT_PAGES=4

# Substring used to pick the wholesale GHL pipeline by name (case-insensitive).
FORGE_SCOUT_PIPELINE=wholesal

# --- Anthropic (Scout's OWN Claude key) -------------------------------------
# Optional. Scout's dedicated scoring key. If unset, Scout FALLS BACK to the
# shared wholesale Anthropic key (../marcus-wholesale-agent/config/).
# SCOUT_ANTHROPIC_API_KEY=sk-ant-...

# --- Obsidian brain (vault) -------------------------------------------------
# Optional override for the Agentic-OS Obsidian vault path. Scout reads its
# learned playbook from <vault>/Skills/scout-playbook.md in addition to the
# local skills/scout-playbook.md in this folder.
# FORGE_VAULT=/Users/yg4st/Desktop/Agentic-OS/vault
