# Private runtime config. Copy to daycare.env and fill values locally.
# Never commit daycare.env, JWTs, service-role keys, database passwords, or PINs.
DAYCARE_SUPABASE_URL=https://PROJECT_REF.supabase.co
DAYCARE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
DAYCARE_SUPABASE_LOCATION_ID=00000000-0000-0000-0000-000000000000
DAYCARE_SUPABASE_LOGIN_DOMAIN=login.blessings.app
# Test-only one-click access. Keep the real values in private daycare.env only.
# Set FORGE_DAYCARE_TEST_MODE=0 in /etc/default/forge-reios to restore the Login ID/PIN screen.
# DAYCARE_TEST_ADMIN_LOGIN_ID=BL-ADM-301
# DAYCARE_TEST_ADMIN_PIN=000000
# DAYCARE_TEST_MANAGER_LOGIN_ID=BL-MGR-201
# DAYCARE_TEST_MANAGER_PIN=000000

# ── Auto-admin (box only) — open straight into the console over the loopback tunnel ──
# FORGE_DAYCARE_AUTOADMIN=1 auto-mints an admin session for 127.0.0.1/::1 requests.
# FORGE_DAYCARE_ALLOW_HTTP=1 is honored ONLY for loopback (SSH tunnel); tailnet/public still require HTTPS.
# FORGE_DAYCARE_AUTOADMIN=0
# FORGE_DAYCARE_ALLOW_HTTP=0

# ── GoHighLevel (daycare sub-account) ──
GHL_API_KEY=REPLACE_ME
GHL_LOCATION_ID=REPLACE_ME
# GHL_BASE_URL / GHL_API_VERSION optional (defaults: services.leadconnectorhq.com / 2021-07-28)

# ── Stripe (daycare invoicing) — use a RESTRICTED key (Invoices + Customers write) ──
STRIPE_SECRET_KEY=

# ── Ads + Social (blank = mock mode; fill when ready) ──
META_ACCESS_TOKEN=
METRICOOL_USER_TOKEN=
# METRICOOL_BLOG_ID / METRICOOL_USER_ID may also be required by Metricool
