# =============================================================================
# FORGE AI AGENCY — credentials TEMPLATE (.env.example)
#
# HOW TO USE:
#   1. This is a template only. The REAL file next to it is  agency.env
#   2. To add/replace a key: open  agency.env  and paste your value.
#   3. Restart the connector (or redeploy) so it reloads.
#
# SAFETY:
#   This whole folder is a SIBLING of the web app ("forge rei/"), so it lives
#   OUTSIDE the web-served dir. Nothing here is reachable over HTTP. Keys stay
#   private. This is the agency twin of  ../marcus-wholesale-agent/  — the two
#   NEVER share a key file. Wholesale keys do not belong in here, and vice versa.
# =============================================================================

# --- GoHighLevel (AGENCY sub-account — NOT the wholesale location) -----------
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=your_agency_location_id
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# --- Anthropic (agency's OWN Claude key) ------------------------------------
# Optional. If left blank, the agency falls back to the wholesale Anthropic key.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Retell AI (agency outbound voice) --------------------------------------
# Optional. Only needed when the agency runs its own voice agents.
# RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Room to grow: other agency integrations --------------------------------
# Add any future agency-only keys below, one KEY=value per line.
# OPENAI_API_KEY=
# STRIPE_API_KEY=
# GOOGLE_API_KEY=

# --- M2/M3/M4 live-connector keys (operator fills these in when ready) ------
# Drop in a value and redeploy — that surface flips from mock to live instantly.
# META_ACCESS_TOKEN=                    # Meta Business System User token (ads_read + ads_management)
# META_AD_ACCOUNT_MAP=                  # JSON: {"clientId":"act_123",...}
# N8N_BASE_URL=                         # e.g. https://your-n8n.app.n8n.cloud
# N8N_API_KEY=                          # n8n Settings → API → API key
# METRICOOL_USER_TOKEN=                 # Metricool paid tier → API
# GITHUB_TOKEN=                         # Fine-grained PAT: repo contents + PR
# GITHUB_DEPLOY_MAP=                    # JSON: {"clientId":"owner/repo",...}
