# =============================================================================
# FORGE REI OS — environment reference (.env.example)
# Copy values into the REAL files described below. Do NOT put real keys here.
# =============================================================================
#
# This app reads config from TWO places (not a single .env):
#
#   1) SECRETS  -> a file named  ghl.env  that lives OUTSIDE the web-served dir:
#                    <parent>/marcus-wholesale-agent/config/ghl.env
#                  (parent = the dir ABOVE forge-rei/). The connector loads it at
#                  startup. Never place secrets inside forge-rei/ itself.
#
#   2) RUNTIME KNOBS (FORGE_*) -> set as process env. On the box these live in the
#                  systemd unit (Environment=...). On the Mac, export them or use
#                  start.sh. They are NOT secret.
#
# -----------------------------------------------------------------------------
# 1) SECRETS  (put these in marcus-wholesale-agent/config/ghl.env)
# -----------------------------------------------------------------------------
# GoHighLevel (v2 API, private integration "pit-" token)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=your_location_id
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_USER_EMAIL=you@example.com

# Anthropic (Marcus reply drafting + chat). REQUIRED for Claude-quality replies;
# without it Marcus falls back to static templates.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Retell AI (outbound voice agents). Optional — only the Outbound tab needs it.
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# 1b) FORGE AI AGENCY SECRETS  — SEPARATE GHL sub-account, never mixed with wholesale.
#     Lives in its OWN file:  forge-agency/config/agency.env
#     (box: /opt/forge/forge-agency/config/agency.env). Same key names, different file.
#     Leave blank until you have the agency sub-account key — the Agency workspace
#     shows "not connected" until then. Anthropic/Retell optional (fall back to wholesale).
# GHL_API_KEY=pit-...        # the AGENCY sub-account token
# GHL_LOCATION_ID=...        # the AGENCY location id
# GHL_BASE_URL=https://services.leadconnectorhq.com
# GHL_API_VERSION=2021-07-28

# Market context used by the classifier / drafts
PRIMARY_MARKET=Wilmington
PRIMARY_ZIP=19801
PRIMARY_COUNTY=New Castle
YAHJAIR_PHONE=+13025551234

# -----------------------------------------------------------------------------
# 2) RUNTIME KNOBS  (FORGE_* — process env / systemd Environment=)
# -----------------------------------------------------------------------------
# HTTP bind. 127.0.0.1 on a laptop; 0.0.0.0 on the box (firewall keeps it private).
FORGE_HOST=127.0.0.1
FORGE_PORT=7799

# Path to the Obsidian "brain" vault the dashboard reads/writes.
FORGE_VAULT=/opt/forge/vault

# Marcus poll loop. "1" = this process polls GHL and answers sellers.
# Set "0" on ANY second instance (e.g. your Mac) so only ONE machine texts.
FORGE_MARCUS=1

# TCPA quiet-hours guard for AUTONOMOUS sends (manual approvals are never gated).
# "1" = enforce window; "0" = allow auto-send 24/7 (NOT recommended).
FORGE_QUIET_HOURS=1
FORGE_TZ=America/New_York
FORGE_QUIET_START=8     # hour (0-23) auto-send may begin
FORGE_QUIET_END=21      # hour (0-23) auto-send must stop

# -----------------------------------------------------------------------------
# 3) PUBLIC-EXPOSURE GATE (only if you put this behind nginx on the internet)
# -----------------------------------------------------------------------------
# There is NO application-level login. If you expose port 7799 publicly you MUST
# put auth in front (nginx HTTP Basic Auth / an SSO proxy). See DEPLOY_DIGITALOCEAN.md.
# BASIC_AUTH_USER=forge
# BASIC_AUTH_PASS=set-a-strong-password
